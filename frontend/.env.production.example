# Copy to `.env.production` (gitignored) before production builds.
VITE_API_BASE_URL=https://api.smartchain.rw

# Backend / deployment: set on the API server for OpenAI embeddings (RAG).
OPENAI_API_KEY=your-key-here

# Backend / deployment: Anthropic API key for copilot answer synthesis.
ANTHROPIC_API_KEY=your-key-here

# Backend / deployment: OAuth2 authorization-code social login (Google + Microsoft).
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
OAUTH2_REDIRECT_URI=https://app.smartchain.rw/auth/oauth2/callback
