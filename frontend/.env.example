VITE_API_BASE_URL=http://localhost:8080
# Demo tenant (V60 Rwanda retail seed) — use with dev CEO login from V41 seed
VITE_DEFAULT_TENANT_ID=11111111-1111-4111-8111-111111111111
VITE_DEFAULT_USER_ID=22222222-2222-4222-8222-222222222222
# Option C: client-side ID token flow (optional; server redirect uses GOOGLE_CLIENT_ID on backend)
VITE_GOOGLE_CLIENT_ID=
VITE_MICROSOFT_CLIENT_ID=
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0
# Rwanda RRA EFD device secret — never commit the real value
VITE_EFD_DEVICE_SECRET=your_secret_here
VITE_RRA_TIN=000000000
# MoMo / Airtel USSD checkout (Sprint 2)
VITE_MOMO_USSD_CODE=*182*8*1#
VITE_AIRTEL_USSD_CODE=*185*9*1#
VITE_MOMO_MERCHANT_CODE=
VITE_AIRTEL_MERCHANT_CODE=
