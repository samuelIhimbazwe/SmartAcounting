# Copy to .env.production for docker compose -f docker-compose.prod.yml

DB_NAME=smartchain
DB_USERNAME=smartchain
DB_PASSWORD=change-me-strong-db-password

# Minimum 64 characters required in prod (ProdSecretsValidator)
JWT_SECRET=change-me-long-random-jwt-secret-at-least-sixty-four-characters-long-for-production
JWT_KEY_ID=smartaccounting-k1

CORS_ALLOWED_ORIGINS=http://localhost,https://app.yourdomain.com
DOMAIN=app.yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com
WEB_PORT=80
WEB_TLS_PORT=443
BACKUP_BUCKET=
GRAFANA_PASSWORD=changeme
VITE_SENTRY_DSN=
SENTRY_DSN=

# Android release signing (mobile)
KEYSTORE_PATH=
KEYSTORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=
MOMO_ALLOWED_IPS=

# AI (required when SMARTACCOUNTING_AI_FAIL_ON_MISSING_PROVIDER_KEYS=true)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
SMARTACCOUNTING_AI_FAIL_ON_MISSING_PROVIDER_KEYS=true

# Mobile money (required if accepting MoMo callbacks)
MOBILE_MONEY_MTN_WEBHOOK_SECRET=
MOBILE_MONEY_AIRTEL_WEBHOOK_SECRET=

# SMS (set SMS_ENABLED=true when live; Africa's Talking: https://api.africastalking.com)
SMS_ENABLED=false
SMS_PROVIDER_URL=https://api.africastalking.com/version1/messaging
SMS_BEARER_TOKEN=
SMS_SENDER_ID=SMARTACCT
SMS_AT_USERNAME=

# RRA EFD / EBM (confirm URLs with RRA)
RRA_EFD_API_URL=https://efds.rra.gov.rw
RRA_EFD_DEVICE_SERIAL=
RRA_EFD_TIN=
RRA_EFD_API_KEY=
RRA_EFD_DEVICE_SECRET=

# MTN MoMo Collections
MOMO_STK_ENABLED=false
MOMO_STK_BASE_URL=https://proxy.momoapi.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_CALLBACK_URL=https://api.rw.smartaccounting.app/api/v1/webhooks/momo
MOMO_ENVIRONMENT=production
MOMO_VERIFY_ENABLED=false
MOMO_MTN_VERIFY_URL=
MOMO_VERIFY_BEARER_TOKEN=

# WhatsApp Business (Meta Graph API)
WHATSAPP_ENABLED=false
WHATSAPP_DRY_RUN=true
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=smartaccounting_receipt
WHATSAPP_USE_TEMPLATE=false

FORECAST_BASE_URL=http://forecast-service:8090

# OAuth2 (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SMARTACCOUNTING_OAUTH2_REDIRECT_URI=http://localhost/auth/oauth2/callback

# Leave empty when using nginx same-origin proxy
VITE_API_BASE_URL=

# Firebase Cloud Messaging (push notifications)
FCM_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json

# E2E / smoke test credentials (monitoring tenant — not production users)
E2E_CEO_EMAIL=monitor-ceo@rw.smartaccounting.app
E2E_CFO_EMAIL=monitor-cfo@rw.smartaccounting.app
E2E_ACCT_EMAIL=monitor-acct@rw.smartaccounting.app
E2E_HR_EMAIL=monitor-hr@rw.smartaccounting.app
E2E_CASHIER_EMAIL=monitor-cashier@rw.smartaccounting.app
E2E_PASSWORD=
E2E_TENANT_ID=11111111-1111-4111-8111-111111111111
