# SmartAccounting local development — copy to .env and fill in values.
# Backend reads these when started via IDE or: set in shell before .\gradlew.bat bootRun

# --- Option A: Anthropic copilot (real prose vs stub) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: embeddings for RAG (OpenAI)
OPENAI_API_KEY=

# --- Option C: Google / Microsoft OAuth2 redirect flow (server-side) ---
# Register redirect URI: http://localhost:8080/api/v1/auth/oauth2/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Register redirect URI: http://localhost:8080/api/v1/auth/oauth2/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Frontend SPA callback (must match smartaccounting.oauth2.redirect-uri)
SMARTACCOUNTING_OAUTH2_REDIRECT_URI=http://localhost:5173/auth/oauth2/callback

# --- Database (matches docker-compose.yml) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/smartchain
SPRING_DATASOURCE_USERNAME=smartchain
SPRING_DATASOURCE_PASSWORD=smartchain

# --- Demo tenant (Option B — V60 migration seeds Rwanda retail figures) ---
# Login with tenant/user from V41 dev seed; CEO dashboard shows ~12.45M FRW revenue.
DEMO_TENANT_ID=11111111-1111-4111-8111-111111111111
DEMO_USER_ID=22222222-2222-4222-8222-222222222222

JWT_SECRET=change-me-enterprise-secret-change-in-prod
