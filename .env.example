# SmartAccounting local development — copy to .env and fill in values.
# Backend reads these when started via IDE or: set in shell before .\gradlew.bat bootRun

# --- Option A: Anthropic copilot (real prose vs stub) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: embeddings for RAG (OpenAI)
OPENAI_API_KEY=

# --- Option C: Google / Microsoft OAuth2 redirect flow (server-side) ---
# Register redirect URI: http://localhost:8080/api/v1/auth/oauth2/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Register redirect URI: http://localhost:8080/api/v1/auth/oauth2/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Frontend SPA callback (must match smartaccounting.oauth2.redirect-uri)
SMARTACCOUNTING_OAUTH2_REDIRECT_URI=http://localhost:5173/auth/oauth2/callback

# --- Database (matches docker-compose.yml) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/smartchain
SPRING_DATASOURCE_USERNAME=smartchain
SPRING_DATASOURCE_PASSWORD=smartchain

# --- Demo tenant (Option B — V60 migration seeds Rwanda retail figures) ---
# Login with tenant/user from V41 dev seed; CEO dashboard shows ~12.45M FRW revenue.
DEMO_TENANT_ID=11111111-1111-4111-8111-111111111111
DEMO_USER_ID=22222222-2222-4222-8222-222222222222

JWT_SECRET=change-me-enterprise-secret-change-in-prod

# --- Phase 6 integrations (production / staging) ---
# WhatsApp Business API (receipt delivery)
SMARTACCOUNTING_WHATSAPP_ENABLED=false
SMARTACCOUNTING_WHATSAPP_DRY-RUN=true
SMARTACCOUNTING_WHATSAPP_API-URL=https://graph.facebook.com/v19.0
SMARTACCOUNTING_WHATSAPP_BEARER-TOKEN=
SMARTACCOUNTING_WHATSAPP_PHONE-NUMBER-ID=

# SMS — routes +250 numbers to MTN (78/79) or Airtel (72/73) gateways
SMARTACCOUNTING_SMS_ENABLED=false
SMARTACCOUNTING_SMS_DRY-RUN=true
SMARTACCOUNTING_SMS_ROUTE-BY-NETWORK=true
# MTN Rwanda bulk SMS / aggregator endpoint
SMARTACCOUNTING_SMS_MTN_PROVIDER-URL=
SMARTACCOUNTING_SMS_MTN_BEARER-TOKEN=
SMARTACCOUNTING_SMS_MTN_SENDER-ID=SmartAccounting
# Airtel Rwanda bulk SMS / aggregator endpoint
SMARTACCOUNTING_SMS_AIRTEL_PROVIDER-URL=
SMARTACCOUNTING_SMS_AIRTEL_BEARER-TOKEN=
SMARTACCOUNTING_SMS_AIRTEL_SENDER-ID=SmartAccounting
# Fallback for non-Rwanda or unknown prefixes
SMARTACCOUNTING_SMS_PROVIDER-URL=
SMARTACCOUNTING_SMS_BEARER-TOKEN=

# USSD / MoMo reference verify (MTN & Airtel HTTP verify endpoints)
SMARTACCOUNTING_MOBILE-MONEY_VERIFY-ENABLED=false
SMARTACCOUNTING_MOBILE-MONEY_MTN-VERIFY-URL=
SMARTACCOUNTING_MOBILE-MONEY_AIRTEL-VERIFY-URL=
SMARTACCOUNTING_MOBILE-MONEY_VERIFY-BEARER-TOKEN=

# RRA EIS / EFD (live fiscal) — see smartaccounting.rra.rwanda.enabled
SMARTACCOUNTING_RRA_RWANDA_ENABLED=false
RRA_EIS_API_TOKEN=
